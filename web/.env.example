# Copy to `.env.local` for local overrides (do not commit real tokens or production URLs with secrets).

# Set to `1` to show the subscriber token screen before the app loads CSV data.
# Session is stored in sessionStorage (clears when the browser tab is closed).
# VITE_ACCESS_GATE=1

# HTTPS URL you control: POST JSON `{ "token": "..." }`, return HTTP 200 when valid.
# Optional JSON body `{ "valid": false }` rejects even on 200.
# Your endpoint must send CORS headers allowing this site’s origin.
# VITE_TOKEN_VALIDATE_URL=https://example.com/api/tmd/validate-token

# Dev only: if VITE_TOKEN_VALIDATE_URL is unset, `npm run dev` can accept this exact token.
# Not used in production builds. Do not use for real access control.
# VITE_DEV_TOKEN=local-test-token

# --- React + Django split stack ---
# Optional absolute API origin for production static hosting (omit in dev to use Vite /api proxy).
# VITE_API_BASE_URL=https://api.yourdomain.com

# Dev: where Vite proxies /api (see web/vite.config.ts).
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Dev only: bypass /access and read CSV/JSON from /output/ (never in production).
# VITE_DEV_SKIP_AUTH=1
