# Copy to `.env.local` for local overrides (do not commit secrets).
#
# Open source / GitHub Pages (default): leave VITE_ACCESS_GATE unset.
# The app loads data from `output/` (see README “GitHub Pages”).
#
# GitHub project page at https://user.github.io/RepoName/ — build with:
#   VITE_BASE_URL=/RepoName/
# so fetches go to https://user.github.io/RepoName/output/...
# Optional: VITE_OUTPUT_BASE_URL=https://user.github.io/RepoName/output
#
# Optional: require login and load datasets from your own API (not shipped in this repo):
# VITE_ACCESS_GATE=1
# VITE_API_BASE_URL=https://api.yourdomain.com

# VITE_ACCESS_GATE=1

# Optional absolute API origin when using VITE_ACCESS_GATE=1.
# VITE_API_BASE_URL=https://api.yourdomain.com

# Dev only: bypass /access and read CSV/JSON from /output/ (never use in production).
# VITE_DEV_SKIP_AUTH=1
