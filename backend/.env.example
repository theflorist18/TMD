# Copy to ``backend/.env`` (gitignored). Django loads it at startup so ``runserver``
# and ``create_subscriber_token`` share the same ``SUBSCRIBER_TOKEN_PEPPER``.

DJANGO_SECRET_KEY=change-me-to-long-random
# 1 for local dev, 0 for production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Optional non-default admin URL path (no leading slash)
# DJANGO_ADMIN_PATH=secret-admin

# Required when DJANGO_DEBUG=0 — long random, never commit real value
# SUBSCRIBER_TOKEN_PEPPER=

TMD_DATA_ROOT=../output
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional when TLS terminates in front of Django
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SECURE_HSTS_SECONDS=31536000
